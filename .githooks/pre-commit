#!/usr/bin/env bash
# Regenerate catalog.json from demos/*/playground.json before each commit.
# REQ-AVA-AUTO-004: catalog auto-maintenance, no other side effects.

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Skip if no relevant files are staged.
if ! git diff --cached --name-only | grep -qE '^(demos/|catalog\.json$)'; then
  exit 0
fi

python3 scripts/build_catalog.py

if ! git diff --quiet -- catalog.json; then
  git add catalog.json
fi
